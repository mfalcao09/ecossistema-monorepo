# LiteLLM proxy — variáveis de ambiente (Railway)
# NUNCA commitar .env real. Apenas este .env.example.

# ------------------ Providers ------------------
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
GEMINI_API_KEY=xxxxx
MARITACA_API_KEY=xxxxx

# ------------------ Master + DB + Redis ------------------
# Gerar master key aleatória:  openssl rand -hex 32
LITELLM_MASTER_KEY=sk-litellm-master-<HEX-64>

# Postgres do Supabase ECOSYSTEM, schema litellm_proxy.
# Forçar schema via search_path para não poluir public.
DATABASE_URL=postgresql://USER:PASS@HOST:5432/postgres?options=-c%20search_path%3Dlitellm_proxy,public

# Redis (Railway Redis add-on ou Upstash)
REDIS_HOST=xxx.railway.internal
REDIS_PORT=6379
REDIS_PASSWORD=xxxxx

# ------------------ Langfuse (S9 preenche URL real) ------------------
LANGFUSE_HOST=https://langfuse.ecossistema.internal
LANGFUSE_PUBLIC_KEY=pk-lf-placeholder
LANGFUSE_SECRET_KEY=sk-lf-placeholder
