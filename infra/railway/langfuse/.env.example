# Langfuse self-host — secrets
#
# Como gerar cada um:
#   POSTGRES_PASSWORD    = openssl rand -base64 32
#   CLICKHOUSE_PASSWORD  = openssl rand -base64 32
#   REDIS_PASSWORD       = openssl rand -base64 32
#   NEXTAUTH_SECRET      = openssl rand -base64 32
#   SALT                 = openssl rand -base64 32
#   ENCRYPTION_KEY       = openssl rand -hex 32   # 64 chars hex — NÃO usar base64
#   OWNER_PASSWORD       = forte, 16+ chars, trocar após primeiro login
#
# ⚠️ CRÍTICO: salve ENCRYPTION_KEY em ≥2 lugares (Supabase Vault + 1Password).
#    Perdeu = todos os dados cifrados (API keys de projetos, integrações) são inacessíveis.
#
# Copie este arquivo para .env e preencha. .env NUNCA é commitado.

# Databases
POSTGRES_PASSWORD=
CLICKHOUSE_PASSWORD=
REDIS_PASSWORD=
MINIO_ROOT_PASSWORD=

# Langfuse core
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
SALT=
ENCRYPTION_KEY=

# Admin inicial (criado no primeiro boot)
OWNER_EMAIL=marcelo@ecossistema.local
OWNER_PASSWORD=
