{
  "name": "@ecossistema/memory",
  "version": "0.2.0",
  "description": "Cliente can\u00f4nico de memory_episodic/semantic/procedural no Supabase ECOSYSTEM \u2014 V9 \u00a732/\u00a740. Mem0-wrapper + pgvector 3-tier + hybrid retrieval.",
  "type": "module",
  "main": "./dist/index.js",
