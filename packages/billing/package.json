{
  "name": "@ecossistema/billing",
  "version": "0.1.0",
  "description": "Motor de cobrança reutilizável — Banco Inter, idempotência, webhook. Art. III + VIII",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
