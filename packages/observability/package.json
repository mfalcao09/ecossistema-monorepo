{
  "name": "@ecossistema/observability",
  "version": "0.1.0",
  "description": "Wrapper TypeScript para Langfuse com defaults V9 \u2014 traces, generations e flush para o Ecossistema.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
