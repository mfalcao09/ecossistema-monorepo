{
  "name": "@ecossistema/credentials",
  "version": "0.1.0",
  "description": "Cliente TypeScript para o SC-29 credential-gateway Edge Function — proxy seguro, nunca expõe chaves.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
