{
  "name": "@ecossistema/whatsapp-gateway",
  "version": "0.1.0",
  "description": "Gateway WhatsApp — Baileys direto (Nível 2, ADR-017). Multi-instância, auth state em Supabase, provider-agnóstico pra swap futuro.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
