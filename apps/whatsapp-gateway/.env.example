# @ecossistema/whatsapp-gateway — .env.example
#
# Copia pra .env.local em dev (NUNCA commitar .env.local).
# Em prod (Railway), vars são injetadas via dashboard ou credential-gateway v2.

# ── Supabase (DB + auth state + realtime) ────────────────────────────────
# URL do projeto Supabase per-tenant (jarvis-pessoal em dev)
SUPABASE_URL=https://nasabljhngsxwdcprwme.supabase.co

# Anon key — pública (vai pro browser). Safe no .env.example.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5hc2FibGpobmdzeHdkY3Byd21lIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY2NDE4MjQsImV4cCI6MjA5MjIxNzgyNH0.Ml1ZxNDkw27snU4PQTB7wGgwQ8HF9OAMVv-rUeDmQ9o

# Service role key — SECRET. Em prod vem do credential-gateway v2 (SC-29 Modo B).
# Em dev local, copia da dashboard do jarvis-pessoal.
SUPABASE_SERVICE_ROLE_KEY=

# ── HTTP ─────────────────────────────────────────────────────────────────
PORT=3030
HOST=0.0.0.0

# Bearer token que protege a API do gateway (gera um aleatório longo).
# Ex: `openssl rand -hex 32`
GATEWAY_BEARER_TOKEN=

# ── Baileys ──────────────────────────────────────────────────────────────
# Label visível no WhatsApp → Dispositivos conectados
BAILEYS_BROWSER_NAME=Ecossistema Gateway

# ── Reliability ──────────────────────────────────────────────────────────
# Frequência do heartbeat por instância (segundos)
HEALTH_HEARTBEAT_INTERVAL_SEC=60
# Frequência do canary (mensagem pra si mesmo) — em segundos. 0 = desabilitado
HEALTH_CANARY_INTERVAL_SEC=3600
# Quantos snapshots de auth_state manter por instância
AUTH_SNAPSHOT_KEEP=3

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=info
# dev | prod — afeta pretty-printing
NODE_ENV=dev
