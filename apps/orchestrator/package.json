{
  "name": "@ecossistema/orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Orquestrador do ecossistema — Python (claudinho_orchestrator.py, V8.2) + camada TS de composição de agentes V9 (compose-agent.ts). S10 da Fase 0 migrará o Python para FastAPI Railway.",
  "type": "module",
  "main": "./dist/compose-agent.js",
  "types": "./dist/compose-agent.d.ts",
  "exports": {
    "./compose-agent": {
      "types": "./dist/compose-agent.d.ts",
      "import": "./dist/compose-agent.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ecossistema/memory": "workspace:*",
    "@ecossistema/constitutional-hooks": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
