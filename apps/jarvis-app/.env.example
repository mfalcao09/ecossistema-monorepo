# Copie para .env.local e preencha. Nunca commitar o .env.local.
#
# EXPO_PUBLIC_* são as únicas env vars expostas ao bundle client-side do Expo.
# No iPhone testando via Expo Go: use o IP LAN do seu Mac, não localhost.

# URL do orchestrator (apps/orchestrator)
#   - Local no Mac (web): http://localhost:8000
#   - Celular via Expo Go: http://<IP_LAN_DO_MAC>:8000
#   - Railway deploy:     https://<subdomínio>.up.railway.app
EXPO_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000

# Bearer token aceito pelo orchestrator (require_auth).
# Opções:
#   1. Owner token (prefixo "owner_"): deve bater com OWNER_TOKEN_HASH no orchestrator
#   2. JWT assinado com JWT_SECRET do orchestrator
# Exemplo owner: owner_dev_local_seguro_1234
EXPO_PUBLIC_ORCHESTRATOR_TOKEN=

# Agent ID alvo — default claudinho (VP do ecossistema)
EXPO_PUBLIC_AGENT_ID=claudinho

# ── Voz (PR 3/4) ──────────────────────────────────────────────────────────
# O app descobre automaticamente se STT/TTS estão ativos via
# GET /voice/health. As envs abaixo são do BACKEND (apps/orchestrator):
#   GROQ_API_KEY        — STT Whisper  (https://console.groq.com)
#   ELEVENLABS_API_KEY  — TTS           (https://elevenlabs.io)
# Se não setadas, botão mic fica desabilitado + resposta não toca em voz.
