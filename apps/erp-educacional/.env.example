NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role key — NUNCA exponha no frontend (sem prefixo NEXT_PUBLIC_)
# Obtenha em: supabase.com → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Segurança ────────────────────────────────────────────────
# Chave para criptografia de dados pessoais (PII) — mínimo 32 caracteres
# Gere com: openssl rand -base64 48
PII_ENCRYPTION_KEY=your_pii_encryption_key_min_32_chars

# Chave para assinatura de operações críticas (HMAC-SHA256) — mínimo 32 caracteres
# Gere com: openssl rand -base64 48
REQUEST_SIGNING_SECRET=your_request_signing_secret_min_32_chars

# ── Rate Limiting (Upstash Redis) ────────────────────────────
# Opcional: se não configurado, usa rate limiting em memória (dev)
# Crie uma conta gratuita em: upstash.com
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Chave para criptografia de backups — mínimo 32 caracteres (separada da chave de produção)
# Gere com: openssl rand -base64 48
# Esta chave é usada apenas para criptografar backups do banco de dados
BACKUP_ENCRYPTION_KEY=your_backup_encryption_key_min_32_chars

# ── Cron Jobs (Vercel) ────────────────────────────────────────────
# Chave secreta para autorizar requisições de cron jobs
# Gere com: openssl rand -base64 32
CRON_SECRET=your_cron_secret_min_32_chars

# ── Atendimento — RBAC granular (S6) ─────────────────────────────
# Feature flag das permissões granulares do módulo Atendimento.
# Quando "false" (default), requirePermission retorna sempre true
# (backward-compat com S1-S5 antes de treinar operadores FIC).
# Ative em stages: dev → staging → prod após validar o fluxo.
ATENDIMENTO_RBAC_ENABLED=false
# Variante pública usada pelo hook useCan() no client
NEXT_PUBLIC_ATENDIMENTO_RBAC_ENABLED=false
