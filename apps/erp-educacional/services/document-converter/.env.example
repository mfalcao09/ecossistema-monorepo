# ============================================
# DocumentConverter — Variáveis de Ambiente
# Copie este arquivo para .env e preencha
# ============================================

# Porta do servidor (padrão: 3100)
PORT=3100

# Chave de API para autenticação interna entre serviços
# O Next.js usa esta chave ao chamar o microserviço
# Gere uma chave segura: openssl rand -hex 32
CONVERTER_API_KEY=sua-chave-secreta-aqui

# Nível de log (debug, info, warn, error)
LOG_LEVEL=info

# Caminho do veraPDF (opcional — usa o padrão do Dockerfile)
# VERAPDF_PATH=/opt/verapdf/verapdf-greenfield-1.26.2/verapdf
