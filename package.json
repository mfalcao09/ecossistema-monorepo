{
  "name": "ecossistema-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Ecossistema de Inovação e IA — Marcelo Silva · Monorepo canônico (V4)",
  "author": "Marcelo Silva <mrcelooo@gmail.com>",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules",
    "prepare": "husky",
    "create-mcp-server": "node packages/mcp-servers/generator/bin/create-mcp-server.js"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^25.6.0",
    "turbo": "^2.3.0",
    "husky": "^9.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.0"
  }
}
