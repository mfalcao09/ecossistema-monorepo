#!/bin/sh

# Roda testes nos packages afetados antes de push
# Evita subir código quebrado para o remote

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Nunca bloqueia push para branches de feature (apenas avisa)
if [ "$CURRENT_BRANCH" = "main" ]; then
  echo "Push para main — rodando testes completos..."
  pnpm turbo test
else
  echo "Rodando testes afetados para branch $CURRENT_BRANCH..."
  pnpm turbo test --filter="...[origin/$CURRENT_BRANCH]" 2>/dev/null || pnpm turbo test
fi
